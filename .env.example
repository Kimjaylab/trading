# 이 파일을 .env로 복사한 뒤 실제 값을 채워넣으세요.
#   cp .env.example .env
# .env는 .gitignore에 이미 포함되어 있어 git에 커밋되지 않습니다.
# 절대 실제 키가 채워진 .env 파일을 커밋하거나 채팅/이슈 등에 붙여넣지 마세요.
#
# 모의투자 키와 실전 키를 같은 .env에 번갈아 채워넣으면 실수로 섞일 위험이 있다.
# .env.virtual, .env.real처럼 따로 만들어두고 스크립트 실행 시 --env-file로
# 지정하는 걸 권장한다 (예: python scripts/run_live.py --env-file .env.real --no-virtual).
# .gitignore의 ".env*" 패턴이 이런 파일들도 함께 커밋 방지해준다.

# KIS Developers (apiportal.koreainvestment.com)에서 발급받은 값
KIS_APP_KEY=여기에_본인_앱키
KIS_APP_SECRET=여기에_본인_시크릿
KIS_ACCOUNT_NO=여기에_본인_계좌번호
# 보통 01. 계좌번호 뒤 2자리가 다르면 그 값으로 변경
KIS_ACCOUNT_PRODUCT_CODE=01
